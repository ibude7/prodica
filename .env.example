# --- Client (Vite) Firebase ---
# Optional overrides; defaults ship for project prodica1
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
# VITE_FIREBASE_AI_MODEL=gemini-3.5-flash
# VITE_FIREBASE_AI_FALLBACK_MODEL=gemini-2.5-flash
# VITE_FIREBASE_VERTEX_LOCATION=global

# App Check (required when Firebase enforces AI Logic)
# VITE_FIREBASE_APPCHECK_SITE_KEY=
# VITE_FIREBASE_APPCHECK_PROVIDER=v3
# VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=your-registered-debug-uuid

# Optional absolute API origin for the Vite client
# VITE_API_BASE=

# --- Server /v1/identify (Vertex AI preferred) ---
# Uses Vertex on project prodica1. Auth (pick one):
#   1) gcloud auth login + gcloud auth application-default login (local)
#   2) GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
#   3) GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"authorized_user",...}' (Render)
GOOGLE_CLOUD_PROJECT=prodica1
GOOGLE_CLOUD_LOCATION=global
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
# GOOGLE_APPLICATION_CREDENTIALS_JSON=
# VERTEX_AI=0 to disable Vertex and use Gemini Developer API key instead
# GEMINI_GROUNDING=0 to skip Google Search grounding for reference URLs
# GEMINI_API_KEY=
# AI_GATEWAY_API_KEY=
# Optional Google Custom Search Image API (booster for reference images)
# GOOGLE_CSE_KEY=
# GOOGLE_CSE_CX=
# PORT=3030
