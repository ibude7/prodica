# --- Client (Vite) Firebase ---
# Optional overrides; defaults ship for project prodica1
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
# VITE_FIREBASE_AI_MODEL=gemini-2.5-flash

# App Check (required when Firebase enforces AI Logic — default for new projects)
# From Firebase Console → App Check → register Web app → reCAPTCHA site key
# VITE_FIREBASE_APPCHECK_SITE_KEY=
# VITE_FIREBASE_APPCHECK_PROVIDER=v3
# After console shows “AppCheck debug token: …”, register it, then optionally:
# VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=your-registered-debug-uuid

# Optional absolute API origin for the Vite client
# VITE_API_BASE=

# --- Server (Render / local API) fallback for /v1/identify ---
GEMINI_API_KEY=
# Also accepted: GOOGLE_GENERATIVE_AI_API_KEY or GOOGLE_API_KEY
# GEMINI_MODEL=gemini-2.5-flash
# AI_GATEWAY_API_KEY=
# PORT=3030
