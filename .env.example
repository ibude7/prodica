# Server-side only — required for POST /v1/identify (pick one)

# Google AI Studio / Gemini (preferred if set)
GEMINI_API_KEY=
# Also accepted: GOOGLE_GENERATIVE_AI_API_KEY or GOOGLE_API_KEY
# Optional model override (default gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Or Vercel AI Gateway
# AI_GATEWAY_API_KEY=

# Optional API port (default 3030)
# PORT=3030

# Optional absolute API origin for the Vite client (omit when using npm run dev:full proxy)
# VITE_API_BASE=
